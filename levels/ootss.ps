=======
LEGEND
=======

Mirror = MirrorUL or MirrorUR or MirrorDL or MirrorDR
Counter = 00 or 01 or 02 or 03 or 04 or 05 or 06 or 07 or 08 or 09
Dragon = DragonLeft or DragonRight or DragonUp or DragonDown
Player = Fighter or Wizard or Thief or Priest
SPlayer = Swizard or Sthief or SFighter or SPriest
Hero = Player or Splayer
Healer = Priest or SPriest (Unlike the other heroes, priests must function even when inactive. "Healer" is the generic term for an active or inactive priest.)
ClosedDoor = PurpleDoor or YellowDoor or MonsterDoor
OpenDoor = YellowOpen or PurpleOpen
Switch = PurpleSwitch or YellowSwitch
Monster = Dragon or Goblin


Crate = NormalCrate or ReflectableCrate

Pushable = Mirror or Crate

Solid = Player or Wall or Crate or Mirror

Reflectable = Player or ReflectableCrate


Moveable = Crate or SPlayer or Monster or Mirror
Static = Wall or ClosedDoor
Weighing = Crate or Hero or Monster
Vulnerable = Hero or Monster
Invulnerable = Crate or Static
Fireball = LFireball or RFireball or UFireball or DFireball
DirectionCounter = North or South or East or West


/ = MirrorUL
\ = MirrorUR
` = MirrorDL
' = MirrorDR


@ = Bush

. = Background
# = Wall
F = Fighter
W = Wizard
T = Thief
P = Priest
1 = SFighter
2 = SThief
3 = SWizard
4 = SPriest
~ = NormalCrate
* = ReflectableCrate
G = Goal
[ = YellowDoor
] = PurpleDoor
{ = YellowSwitch
} = PurpleSwitch
L = DragonLeft
R = DragonRight
U = DragonUp
D = DragonDown
O = Goblin
M = MonsterDoor

WaterAnim = WaterAnim1 or WaterAnim2
_ = Hole and WaterAnim1


