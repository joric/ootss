=======
LEGEND
=======

Dragon = DragonLeft or DragonRight or DragonUp or DragonDown
Player = Fighter or Wizard or Thief or Priest or Bard or Druid
SPlayer = Swizard or Sthief or SFighter or SPriest or SBard or SDruid
Hero = Player or Splayer
Healer = Priest or SPriest (Unlike the other heroes, priests must function even when inactive. "Healer" is the generic term for an active or inactive priest.)
ClosedDoor = PurpleDoor or YellowDoor or MonsterDoor
OpenDoor = YellowOpen or PurpleOpen
Switch = PurpleSwitch or YellowSwitch
Monster =  Dragon or Goblin
FrozenMonster = FrozenGoblin or FrozenDragonUp or FrozenDragonLeft or FrozenDragonRight or FrozenDragonDown
Moveable = Crate or SPlayer or Monster or FrozenMonster
Static = Wall or ClosedDoor or Bush
Weighing = Crate or Hero or Monster or Wall or Bush or FrozenMonster
Vulnerable = Hero or Monster
Invulnerable = Crate or Static

_ = Hole

. = Background
# = Wall
F = Fighter
W = Wizard
T = Thief
P = Priest
B = Bard
I = Druid
1 = SFighter
2 = SThief
3 = SWizard
4 = SPriest
5 = SBard
6 = SDruid

@ = Bush

7 = Goal and Thief
8 = Goal and SWizard
9 = PurpleSwitch and Goblin
0 = YellowSwitch and Goblin
Q = Goal and MonsterDoor
Z = Goal and SFighter
X = Goal and SThief
Y = YellowSwitch and Bard

L = DragonLeft
R = DragonRight
U = DragonUp
D = DragonDown

* = Crate
G = Goal
[ = YellowDoor
] = PurpleDoor
{ = YellowSwitch
} = PurpleSwitch
O = Goblin
M = MonsterDoor

