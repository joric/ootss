=======
LEGEND
=======

Dragon = DragonLeft or DragonRight or DragonUp or DragonDown
Fireball = LFireball or RFireball or UFireball or DFireball
Player = Fighter or Wizard or Thief or Priest or Bard or Druid or MirrorGuy
SPlayer = Swizard or Sthief or SFighter or SPriest or SBard or SDruid
Hero = Player or Splayer
Healer = Priest or SPriest (Unlike the other heroes, priests must function even when inactive. "Healer" is the generic term for an active or inactive priest.)
ClosedDoor = PurpleDoor or YellowDoor or BlueDoor or MonsterDoor
OpenDoor = YellowOpen or PurpleOpen or BlueOpen
Switch = PurpleSwitch or YellowSwitch or BlueSwitch
Monster =  Dragon or Goblin
FrozenMonster = FrozenGoblin or FrozenDragonUp or FrozenDragonLeft or FrozenDragonRight or FrozenDragonDown
Moveable = Crate or SPlayer or Monster or FrozenMonster
Static = Wall or ClosedDoor or Bush
Weighing = Crate or Hero or Monster or Wall or Bush or FrozenMonster
Vulnerable = Hero or Monster
Invulnerable = Crate or Static

(mirror defines)

Mirror = MirrorUL or MirrorUR or MirrorDL or MirrorDR
Counter = 00 or 01 or 02 or 03 or 04 or 05 or 06 or 07 or 08 or 09
DirectionCounter = North or South or East or West

MirrorCrate = NormalCrate or ReflectableCrate

Pushable = Mirror or MirrorCrate

Solid = MirrorCrate or Mirror or Hero or Wall

Reflectable = MirrorGuy or ReflectableCrate

/ = MirrorUL
\ = MirrorUR
` = MirrorDL
' = MirrorDR

WaterHere = Hole or CrateInHole or FloatingBody

AddLandL = AddLandLUD or AddLandLU or AddLandLD
AddLandR = AddLandRUD or AddLandRU or AddLandRD

RemoveLandL = RemoveLandLUD or RemoveLandLU or RemoveLandLD
RemoveLandR = RemoveLandRUD or RemoveLandRU or RemoveLandRD

(---)

Background = HeroBackground

. = Background
# = Wall
F = Fighter
W = Wizard
T = Thief
P = Priest
B = Bard
I = Druid
1 = SFighter
2 = SThief
3 = SWizard
4 = SPriest
5 = SBard
6 = SDruid

@ = Bush

7 = Goal and Thief
8 = Goal and SWizard
9 = PurpleSwitch and Goblin
0 = YellowSwitch and Goblin
Q = Goal and MonsterDoor
Z = Goal and SFighter
E = Goal and Fighter


Y = YellowSwitch and Bard

& = YellowSwitch and Fighter (heroes3_5)
$ = YellowSwitch and SBard    (heroes3_5)

L = DragonLeft
R = DragonRight
U = DragonUp
D = DragonDown

* = Crate
~ = NormalCrate
! = ReflectableCrate
G = Goal
[ = YellowDoor
] = PurpleDoor
{ = YellowSwitch
} = PurpleSwitch
O = Goblin
M = MonsterDoor

C = PurpleOpen
H = BlueDoor
J = BlueOpen
K = BlueSwitch


WaterAnim = WaterAnim1 or WaterAnim2
_ = Hole and WaterAnim1


X = MirrorGuy


