=======
LEGEND
=======

Dragon = DragonLeft or DragonRight or DragonUp or DragonDown
Fireball = LFireball or RFireball or UFireball or DFireball
Player = Fighter or Wizard or Thief or Priest or Bard or Druid or MirrorGuy
SPlayer = Swizard or Sthief or SFighter or SPriest or SBard or SDruid or SMirrorGuy
Hero = Player or Splayer
Healer = Priest or SPriest (Unlike the other heroes, priests must function even when inactive. "Healer" is the generic term for an active or inactive priest.)
Monster =  Dragon or Goblin
FrozenMonster = FrozenGoblin or FrozenDragonUp or FrozenDragonLeft or FrozenDragonRight or FrozenDragonDown
Moveable = Crate or SPlayer or Monster or FrozenMonster
BardMoveable = Crate or SPlayer or Monster or FrozenMonster or CrateInHole
ClosedDoor = YellowDoor or PurpleDoor or BlueDoor or GreenDoor or MonsterDoor
OpenDoor = YellowOpen or PurpleOpen or BlueOpen or GreenOpen
Switch = PurpleSwitch or YellowSwitch or BlueSwitch or GreenSwitch
Static = Wall or ClosedDoor or Bush
Weighing = Crate or Hero or Monster or Wall or Bush or FrozenMonster
Vulnerable = Hero or Monster
Invulnerable = Crate or Static
WaterAnim = WaterAnim1 or WaterAnim2
Background = HeroBackground

DoorSprite = YellowOpenA or PurpleOpenA or BlueOpenA or GreenOpenA or PurpleDoorA or YellowDoorA or BlueDoorA or GreenDoorA

(mirror defines)

Mirror = MirrorUL or MirrorUR or MirrorDL or MirrorDR
Counter = 00 or 01 or 02 or 03 or 04 or 05 or 06 or 07 or 08 or 09
Rays = RayU or RayD or RayL or RayR
DirectionCounter = North or South or East or West
MirrorCrate = NormalCrate or ReflectableCrate
Pushable = Mirror or MirrorCrate
Solid = MirrorCrate or Mirror or Hero or Wall
Reflectable = MirrorGuy or ReflectableCrate
WaterHere = Hole or CrateInHole or FloatingBody or MirrorInHole
AddLandL = AddLandLUD or AddLandLU or AddLandLD
AddLandR = AddLandRUD or AddLandRU or AddLandRD
RemoveLandL = RemoveLandLUD or RemoveLandLU or RemoveLandLD
RemoveLandR = RemoveLandRUD or RemoveLandRU or RemoveLandRD

ColorDoor   = YellowDoor   or BlueDoor   or PurpleDoor   or GreenDoor
ColorOpen   = YellowOpen   or BlueOpen   or PurpleOpen   or GreenOpen
ColorSwitch = YellowSwitch or BlueSwitch or PurpleSwitch or GreenSwitch

Exit = Goal or Target

(single letter defines for levels)

. = Background
# = Wall
_ = Hole and WaterAnim1
* = Crate
/ = MirrorUL
\ = MirrorUR
` = MirrorDL
' = MirrorDR
@ = Bush
~ = NormalCrate
! = ReflectableCrate

(open doors are used in dipping_your_toes_in and dont_push_the_button)


; = BlueDoor
: = BlueOpen
, = BlueSwitch

] = PurpleDoor
? = PurpleOpen
} = PurpleSwitch

[ = YellowDoor
& = YellowOpen
{ = YellowSwitch

$ = GreenDoor
- = GreenOpen
+ = GreenSwitch

% = WaterSeed

(no more characters left - |,<>,[] - give warnings)

(S-prefixed defines mean currently inactive characters to switch to)

0 = SMirrorGuy
1 = SFighter
2 = SThief
3 = SWizard
4 = SPriest
5 = SBard
6 = SDruid
7 = Goal and Thief (heroes1_18)
8 = Goal and SWizard (heroes1_18)
9 = PurpleSwitch and Goblin (heroes2_10.5)

A = MirrorGuy
B = Bard
(C = )
D = DragonDown
E = Goal and Fighter (easy_situation_v2)
F = Fighter
G = Goal
(H = )
I = Druid
J = YellowSwitch and SBard    (heroes3_5)
K = YellowSwitch and Fighter (heroes3_5)
L = DragonLeft
M = MonsterDoor
(N = )
O = Goblin
P = Priest
Q = Goal and MonsterDoor (mosh_pit_small)
R = DragonRight
S = YellowSwitch and Goblin (one_fire_v2)
T = Thief
U = DragonUp
(V = better used with ^ < > v as a directional entity, though warnings)
W = Wizard
(X = )
Y = YellowSwitch and Bard (heroes3_2_v4)
Z = BlueSwitch and DragonLeft (detonator)

