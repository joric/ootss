[ Counter ] -> []
[ Returning ] -> []

(cleanup: dead-end sweep back through unresolved LOS. Crossing cells lose only their Crossing tag first pass, get deleted for real on a later pass once uncontested)
[ action Reflectable ] [ stationary LOS Crossing ] -> [ action Reflectable ] [ LOS ]
[ action Reflectable ] [ stationary LOS no Crossing ] -> [ action Reflectable ] []

[ LOS ] -> [ action LOS ]

[ action Reflectable ] -> [ Reflectable ]

endloop

[ DirectionCounter ] -> []
[ Crossing ] -> []

(reflections and LOS cannot overlap, cancel the entire thing)
[ HasReflection ] [ Reflection LOS ] -> [ ] [ Crossing LOS ]
+[ Crossing ] [ LOS ] -> [ Crossing ] [ ]
+[ Crossing ] [ Reflection ] -> [ Crossing ] [ ]
+[ Crossing ] [ HasReflection ] -> [ Crossing ] [ ]
+[ Crossing ] -> [ ]

(assign proper reflections)
[ BaseReflection ] [ MirrorGuy HasReflection ] -> [ MirrorGuyReflection ] [ MirrorGuy HasReflection ]
[ BaseReflection ] [ SMirrorGuy HasReflection ] -> [ MirrorGuyReflection ] [ SMirrorGuy HasReflection ]
[ BaseReflection ] [ Goblin HasReflection ] -> [ GoblinReflection ] [ Goblin HasReflection ]
[ BaseReflection ] [ ReflectableCrate HasReflection ] -> [ CrateReflection ] [ ReflectableCrate HasReflection ]

